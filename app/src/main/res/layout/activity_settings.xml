<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title bar: app icon + app name, side by side. -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@mipmap/ic_launcher_background"
                android:contentDescription="@string/app_name"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="28sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/enable_ime_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingTop="12dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/enable_ime_summary"
            android:textSize="13sp"
            android:paddingTop="2dp"/>
        <Button
            android:id="@+id/btn_enable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/enable_ime_title"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/choose_ime_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingTop="12dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/choose_ime_summary"
            android:textSize="13sp"
            android:paddingTop="2dp"/>
        <Button
            android:id="@+id/btn_choose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/choose_ime_title"
            android:layout_marginTop="4dp"/>

        <EditText
            android:id="@+id/et_test"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/test_input_hint"
            android:layout_marginTop="16dp"
            android:minLines="3"
            android:inputType="textMultiLine|textNoSuggestions"
            android:importantForAutofill="no"
            android:gravity="top"
            android:padding="8dp"
            android:background="#11000000"/>

        <!-- 偏好容器 -->
        <FrameLayout
            android:id="@+id/settings_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/btn_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pref_clear_history"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/btn_user_dict"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/user_dict_title"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
</ScrollView>
