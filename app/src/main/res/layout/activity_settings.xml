<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/colorBackground"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ============================================================ -->
        <!-- Hero header：深蓝渐变 + 圆角底 + app icon + 名字 + slogan     -->
        <!-- ============================================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_hero"
            android:paddingStart="@dimen/app_hero_padding"
            android:paddingEnd="@dimen/app_hero_padding"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <FrameLayout
                android:layout_width="@dimen/app_hero_icon_size"
                android:layout_height="@dimen/app_hero_icon_size"
                android:background="@drawable/bg_hero_icon"
                android:layout_marginEnd="14dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@mipmap/ic_launcher_background"
                    android:contentDescription="@string/app_name"
                    android:padding="4dp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textAppearance="@style/TextAppearance.App.HeroTitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_tagline"
                    android:textAppearance="@style/TextAppearance.App.HeroSubtitle"
                    android:paddingTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ============================================================ -->
        <!-- 内容区：按分组堆叠 MaterialCardView                            -->
        <!-- ============================================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/app_screen_padding"
            android:paddingEnd="@dimen/app_screen_padding"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- ==== Card 1: 启动步骤 ==== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_setup"
                        android:textAppearance="@style/TextAppearance.App.SectionTitle" />

                    <!-- Step 1 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/enable_ime_title"
                        android:textAppearance="@style/TextAppearance.App.SectionTitle"
                        android:textSize="15sp"
                        android:paddingTop="14dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/enable_ime_summary"
                        android:textAppearance="@style/TextAppearance.App.Body"
                        android:paddingTop="2dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_enable"
                        style="@style/Widget.App.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/enable_ime_title"
                        app:icon="@drawable/ic_keyboard"
                        android:layout_marginTop="10dp" />

                    <!-- Step 2 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/choose_ime_title"
                        android:textAppearance="@style/TextAppearance.App.SectionTitle"
                        android:textSize="15sp"
                        android:paddingTop="18dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/choose_ime_summary"
                        android:textAppearance="@style/TextAppearance.App.Body"
                        android:paddingTop="2dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_choose"
                        style="@style/Widget.App.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/choose_ime_title"
                        app:icon="@drawable/ic_switch"
                        android:layout_marginTop="10dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==== Card 2: 试用区 ==== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/app_card_gap">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_try"
                        android:textAppearance="@style/TextAppearance.App.SectionTitle" />

                    <EditText
                        android:id="@+id/et_test"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/test_input_hint"
                        android:layout_marginTop="10dp"
                        android:minLines="3"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:importantForAutofill="no"
                        android:gravity="top"
                        android:padding="14dp"
                        android:background="@drawable/bg_test_input"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==== Card 3: 偏好设置（单行入口，点开进独立页面） ==== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:id="@+id/btn_open_prefs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/app_card_gap"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_tune"
                        android:layout_marginEnd="14dp"
                        android:contentDescription="@string/section_prefs"
                        android:tint="?attr/colorPrimary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/section_prefs"
                            android:textAppearance="@style/TextAppearance.App.SectionTitle" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_prefs_summary"
                            android:textAppearance="@style/TextAppearance.App.Body"
                            android:paddingTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_chevron_right"
                        android:layout_marginStart="10dp"
                        android:contentDescription="@string/section_prefs_open" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==== Card 4: 数据与词典 ==== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/app_card_gap">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_data"
                        android:textAppearance="@style/TextAppearance.App.SectionTitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_user_dict"
                        style="@style/Widget.App.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/user_dict_title"
                        app:icon="@drawable/ic_book"
                        android:layout_marginTop="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear"
                        style="@style/Widget.App.Button.Text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pref_clear_history"
                        app:icon="@drawable/ic_history"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
